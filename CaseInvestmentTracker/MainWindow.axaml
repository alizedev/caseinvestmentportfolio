<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="CaseInvestmentTracker.MainWindow"
    Width="900"
    Height="600"
    Title="CS2 Case Investment Tracker">


    <Grid RowDefinitions="Auto,*"
          Margin="20">


        <TextBlock
            Text="CS2 Case Investment Portfolio"
            FontSize="28"
            FontWeight="Bold"/>


        <DataGrid
            Grid.Row="1"
            Margin="0,20,0,0"
            ItemsSource="{Binding Cases}">

            <DataGrid.Columns>

                <DataGridTextColumn
                    Header="Case"
                    Binding="{Binding Name}" />

                <DataGridTextColumn
                    Header="Buy Price"
                    Binding="{Binding BuyPrice}" />

                <DataGridTextColumn
                    Header="Current Price"
                    Binding="{Binding CurrentPrice}" />

                <DataGridTextColumn
                    Header="ROI %"
                    Binding="{Binding Roi}" />

            </DataGrid.Columns>

        </DataGrid>


    </Grid>

</Window>