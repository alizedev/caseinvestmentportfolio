<Window x:Class="CaseInvestmentTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CS2 Case Investment Tracker"
        Width="1400"
        Height="850"
        Background="#171A21"
        WindowStartupLocation="CenterScreen">


    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="350"/>
        </Grid.ColumnDefinitions>


        <!-- HEADER -->

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#1B2838"
                CornerRadius="10"
                Padding="20">

            <TextBlock Text="🎮 CS2 Case Investment Tracker"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"/>

        </Border>



        <!-- CASE LIST -->

        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#2A475E"
                CornerRadius="10"
                Margin="0,20,20,0">


            <DataGrid ItemsSource="{Binding Cases}"
                      AutoGenerateColumns="False"
                      Background="#2A475E"
                      Foreground="White"
                      BorderThickness="0"
                      RowBackground="#2A475E">


                <DataGrid.Columns>


                    <DataGridTextColumn Header="Case"
                                        Binding="{Binding Name}"
                                        Width="250"/>


                    <DataGridTextColumn Header="Buy Price"
                                        Binding="{Binding BuyPrice}"
                                        Width="100"/>


                    <DataGridTextColumn Header="Current"
                                        Binding="{Binding CurrentPrice}"
                                        Width="100"/>


                    <DataGridTextColumn Header="Amount"
                                        Binding="{Binding Quantity}"
                                        Width="80"/>


                    <DataGridTextColumn Header="Profit"
                                        Binding="{Binding Profit}"
                                        Width="120"/>


                    <DataGridTextColumn Header="ROI %"
                                        Binding="{Binding ProfitPercent}"
                                        Width="100"/>


                </DataGrid.Columns>


            </DataGrid>


        </Border>



        <!-- RIGHT SIDE -->

        <StackPanel Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,20,0,0">



            <Border Background="#2A475E"
                    CornerRadius="10"
                    Padding="20">


                <StackPanel>


                    <TextBlock Text="Portfolio"
                               Foreground="White"
                               FontSize="26"
                               FontWeight="Bold"/>


                    <Separator Margin="0,15"/>


                    <TextBlock Text="Invested"
                               Foreground="LightGray"/>

                    <TextBlock Text="{Binding TotalInvested, StringFormat='{}{0:C}'}"
                               Foreground="#66C0F4"
                               FontSize="24"/>



                    <TextBlock Text="Current Value"
                               Margin="0,15,0,0"
                               Foreground="LightGray"/>

                    <TextBlock Text="{Binding CurrentValue, StringFormat='{}{0:C}'}"
                               Foreground="#66C0F4"
                               FontSize="24"/>



                    <TextBlock Text="Profit"
                               Margin="0,15,0,0"
                               Foreground="LightGray"/>

                    <TextBlock Text="{Binding TotalProfit, StringFormat='{}{0:C}'}"
                               Foreground="#00FF66"
                               FontSize="24"/>



                    <TextBlock Text="ROI"
                               Margin="0,15,0,0"
                               Foreground="LightGray"/>

                    <TextBlock Text="{Binding ROI, StringFormat='{}{0:F2}%'}"
                               Foreground="Orange"
                               FontSize="24"/>


                </StackPanel>


            </Border>



            <!-- BUTTONS -->


            <Button Content="🔄 Refresh Prices"
                    Height="45"
                    Margin="0,20,0,0"
                    FontSize="16"/>


            <Button Content="➕ Add Case"
                    Height="45"
                    Margin="0,10,0,0"
                    FontSize="16"/>


            <Button Content="💾 Save Portfolio"
                    Height="45"
                    Margin="0,10,0,0"
                    FontSize="16"/>


            <Button Content="📊 Analytics"
                    Height="45"
                    Margin="0,10,0,0"
                    FontSize="16"/>


        </StackPanel>


    </Grid>


</Window>